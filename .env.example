PORT=3000
NODE_ENV=development

# Public site URL (required in production for Paystack callbacks + course links)
PUBLIC_BASE_URL=http://localhost:3000

# Paystack (leave empty for local mock checkout)
PAYSTACK_SECRET_KEY=
PAYSTACK_CURRENCY=USD

# Optional: restrict browser origins (comma-separated). Empty = allow all (dev)
CORS_ORIGINS=

# SMTP — course access emails after payment
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RemoteMedicalJobs <noreply@remotemedicaljobs.com>"

# Where contact form notifications are sent
CONTACT_NOTIFY_EMAIL=
